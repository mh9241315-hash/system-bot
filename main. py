# ملف حفظ الإعدادات تلقائياً
CONFIG_FILE = "system_config.json"

# الآيديهات الافتراضية للرومات (روم كرت الترحيب + روم الشات العام)
DEFAULT_WELCOME_CHANNEL_ID = 1515157531842973888  # روم كارت الترحيب بالصورة
DEFAULT_GENERAL_CHAT_ID = 1513676299066015874     # روم الشات العام المخصصة للمنشن والترحيب السريع

# رابط خلفية الترحيب الفخمة المحددة من قبلك
WELCOME_BG_URL = "https://e.top4top.io/p_3847ysunn0.png"

def load_config():
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            return json.load(f)
    return {
        "welcome_channel": DEFAULT_WELCOME_CHANNEL_ID, 
        "general_chat": DEFAULT_GENERAL_CHAT_ID,
        "welcome_role": None
    }

def save_config(config):
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=4)

# --- دالة رسم كرت الترحيب بالأعضاء الجدد ---
async def create_welcome_card(avatar_url, member_count):
    async with aiohttp.ClientSession() as session:
        async with session.get(WELCOME_BG_URL) as resp:
            if resp.status != 200: return None
            bg_bytes = await resp.read()
        async with session.get(avatar_url) as resp:
            if resp.status != 200: return None
            avatar_bytes = await resp.read()

    background = Image.open(io.BytesIO(bg_bytes)).convert("RGBA")
    avatar = Image.open(io.BytesIO(avatar_bytes)).convert("RGBA")

    # تحديد حجم وموضع الأفاتار ليتناسب تماماً مع الدائرة المخصصة له على اليسار
    avatar_size = (194, 194)
    avatar = avatar.resize(avatar_size, Image.Resampling.LANCZOS)
    
    mask = Image.new("L", avatar_size, 0)
    draw_mask = ImageDraw.Draw(mask)
    draw_mask.ellipse((0, 0) + avatar_size, fill=255)
    
    circular_avatar = ImageOps.fit(avatar, avatar_size, centering=(0.5, 0.5))
    circular_avatar.putalpha(mask)

    # وضع الأفاتار الدائري في إحداثياته الدقيقة على اليسار
    background.paste(circular_avatar, (52, 53), circular_avatar)
    draw = ImageDraw.Draw(background)
    
    try:
        font = ImageFont.truetype("arial.ttf", 45)
    except IOError:
        font = ImageFont.load_default()

    # كتابة رقم الترتيب في الجانب الأيمن من الكرت بخط فخم
    draw.text((630, 160), f"MEMBER #{member_count}", fill="white", font=font, anchor="mm")

    output = io.BytesIO()
    background.save(output, format="PNG")
    output.seek(0)
    return output

